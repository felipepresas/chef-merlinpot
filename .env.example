# ─── Base de datos (PostgreSQL) ───────────────────────────────
# Conexión pooled para la app (serverless). En Neon usa la URL "-pooler".
DATABASE_URL="postgresql://user:pass@host:5432/chef?schema=public"
# Conexión directa para migraciones de Prisma.
DIRECT_URL="postgresql://user:pass@host:5432/chef?schema=public"

# ─── Firebase (cliente / público) ─────────────────────────────
# Se registran en la consola de Firebase → Project settings → Your apps → Web.
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="chef-merlinpot.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="chef-merlinpot"
NEXT_PUBLIC_FIREBASE_APP_ID=""

# ─── Firebase Admin (servidor / secreto) ──────────────────────
FIREBASE_PROJECT_ID="chef-merlinpot"
FIREBASE_CLIENT_EMAIL=""
# Clave privada con \n escapados en una sola línea.
FIREBASE_PRIVATE_KEY=""

# ─── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
