// Chef by merlinpot — esquema de datos.
// Modelo refinado tras docs/AUDIT.md. Si cambias algo aquí, actualiza docs/ARCHITECTURE.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Prisma 7: las URLs de conexión viven en prisma.config.ts, no aquí.
}

// ─── Enums ──────────────────────────────────────────────────────

enum MealType {
  LUNCH
  DINNER
  // Extensible: BREAKFAST, SNACK
}

enum Unit {
  g
  kg
  ml
  l
  ud // unidad
  cs // cucharada sopera
  cc // cucharadita
  diente
  lata
  manojo
  al_gusto
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

// ─── Identidad ──────────────────────────────────────────────────

model User {
  id          String   @id @default(cuid())
  firebaseUid String   @unique
  email       String   @unique
  name        String?
  prefs       Json     @default("{\"householdSize\": 2}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  weekPlans WeekPlan[]
  favorites Favorite[]
}

// ─── Catálogo ───────────────────────────────────────────────────

model Recipe {
  id             String     @id @default(cuid())
  slug           String     @unique
  title          String
  description    String?
  mealType       MealType
  servings       Int        @default(2)
  prepTimeMin    Int?
  cookTimeMin    Int?
  difficulty     Difficulty @default(EASY)
  youtubeVideoId String?
  imageUrl       String?
  steps          Json       @default("[]") // array de { text, durationMin? }
  cuisine        String?
  isSeed         Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  ingredients RecipeIngredient[]
  slots       PlanSlot[]
  favorites   Favorite[]
}

model Ingredient {
  id          String  @id @default(cuid())
  name        String  @unique
  category    String // pasillo del súper (verdura, lácteos, carne...)
  defaultUnit Unit    @default(g)
  isStaple    Boolean @default(false) // despensa habitual → fuera de la compra por defecto

  recipes RecipeIngredient[]
}

model RecipeIngredient {
  id           String  @id @default(cuid())
  recipeId     String
  ingredientId String
  quantity     Float // por Recipe.servings
  unit         Unit
  note         String?

  recipe     Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  @@unique([recipeId, ingredientId, unit])
}

// ─── Plan semanal ───────────────────────────────────────────────

model WeekPlan {
  id            String   @id @default(cuid())
  userId        String
  weekStartDate DateTime // lunes de la semana
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  slots        PlanSlot[]
  shoppingList ShoppingList?

  @@unique([userId, weekStartDate])
}

model PlanSlot {
  id         String   @id @default(cuid())
  weekPlanId String
  dayOfWeek  Int // 0 = lunes ... 6 = domingo
  mealType   MealType
  recipeId   String?

  weekPlan WeekPlan @relation(fields: [weekPlanId], references: [id], onDelete: Cascade)
  recipe   Recipe?  @relation(fields: [recipeId], references: [id])

  @@unique([weekPlanId, dayOfWeek, mealType])
}

// ─── Lista de la compra ─────────────────────────────────────────

model ShoppingList {
  id         String   @id @default(cuid())
  weekPlanId String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  weekPlan WeekPlan       @relation(fields: [weekPlanId], references: [id], onDelete: Cascade)
  items    ShoppingItem[]
}

model ShoppingItem {
  id              String   @id @default(cuid())
  listId          String
  ingredientName  String
  quantity        Float
  unit            Unit
  aisle           String // categoría/pasillo
  checked         Boolean  @default(false)
  sourceRecipeIds String[] // trazabilidad para regenerar sin perder checks

  list ShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)
}

// ─── Favoritos ──────────────────────────────────────────────────

model Favorite {
  userId    String
  recipeId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@id([userId, recipeId])
}
