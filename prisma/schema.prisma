// Chef by merlinpot — esquema de datos.
// Modelo refinado tras docs/AUDIT.md. Si cambias algo aquí, actualiza docs/ARCHITECTURE.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Prisma 7: las URLs de conexión viven en prisma.config.ts, no aquí.
}

// ─── Enums ──────────────────────────────────────────────────────

enum MealType {
  LUNCH
  DINNER
  // Extensible: BREAKFAST, SNACK
}

enum Unit {
  g
  kg
  ml
  l
  ud // unidad
  cs // cucharada sopera
  cc // cucharadita
  diente
  lata
  manojo
  al_gusto
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

// Restricciones dietéticas que una receta cumple / que un usuario requiere.
enum DietTag {
  VEGETARIANO
  VEGANO
  SIN_GLUTEN
  SIN_LACTOSA
}

// ─── Identidad ──────────────────────────────────────────────────

model User {
  id          String   @id @default(cuid())
  firebaseUid String   @unique
  email       String   @unique
  name        String?
  prefs       Json      @default("{\"householdSize\": 2}")
  diets       DietTag[] @default([]) // restricciones dietéticas del usuario
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  householdId String?
  household   Household? @relation(fields: [householdId], references: [id], onDelete: SetNull)

  favorites Favorite[]

  sentFriendships     Friendship[]      @relation("SentFriendships")
  receivedFriendships Friendship[]      @relation("ReceivedFriendships")
  hostedDuels         DuelSession[]     @relation("HostedDuels")
  duelParticipations  DuelParticipant[] @relation("DuelParticipations")

  sentHouseholdInvites     HouseholdInvite[] @relation("SentHouseholdInvites")
  receivedHouseholdInvites HouseholdInvite[] @relation("ReceivedHouseholdInvites")

  @@index([householdId])
}

// ─── Catálogo ───────────────────────────────────────────────────

model Recipe {
  id             String     @id @default(cuid())
  slug           String     @unique
  title          String
  description    String?
  mealType       MealType
  servings       Int        @default(2)
  prepTimeMin    Int?
  cookTimeMin    Int?
  difficulty     Difficulty @default(EASY)
  youtubeVideoId String?
  imageUrl       String?
  steps          Json       @default("[]") // array de { text, durationMin? }
  cuisine        String?
  diets          DietTag[]  @default([]) // dietas que la receta cumple
  isSeed         Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  ingredients RecipeIngredient[]
  slots       PlanSlot[]
  favorites   Favorite[]
}

model Ingredient {
  id          String  @id @default(cuid())
  name        String  @unique
  category    String // pasillo del súper (verdura, lácteos, carne...)
  defaultUnit Unit    @default(g)
  isStaple    Boolean @default(false) // despensa habitual → fuera de la compra por defecto

  recipes RecipeIngredient[]
}

model RecipeIngredient {
  id           String  @id @default(cuid())
  recipeId     String
  ingredientId String
  quantity     Float // por Recipe.servings
  unit         Unit
  note         String?

  recipe     Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  @@unique([recipeId, ingredientId, unit])
}

// ─── Plan semanal ───────────────────────────────────────────────

model WeekPlan {
  id            String   @id @default(cuid())
  householdId   String
  weekStartDate DateTime // lunes de la semana
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  household    Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  slots        PlanSlot[]
  shoppingList ShoppingList?

  @@unique([householdId, weekStartDate])
}

model PlanSlot {
  id         String   @id @default(cuid())
  weekPlanId String
  dayOfWeek  Int // 0 = lunes ... 6 = domingo
  mealType   MealType
  recipeId   String?

  weekPlan WeekPlan @relation(fields: [weekPlanId], references: [id], onDelete: Cascade)
  recipe   Recipe?  @relation(fields: [recipeId], references: [id])

  @@unique([weekPlanId, dayOfWeek, mealType])
}

// ─── Lista de la compra ─────────────────────────────────────────

model ShoppingList {
  id         String   @id @default(cuid())
  weekPlanId String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  weekPlan WeekPlan       @relation(fields: [weekPlanId], references: [id], onDelete: Cascade)
  items    ShoppingItem[]
}

model ShoppingItem {
  id              String   @id @default(cuid())
  listId          String
  ingredientName  String
  quantity        Float
  unit            Unit
  aisle           String // categoría/pasillo
  checked         Boolean  @default(false)
  sourceRecipeIds String[] // trazabilidad para regenerar sin perder checks

  list ShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)
}

// ─── Favoritos ──────────────────────────────────────────────────

model Favorite {
  userId    String
  recipeId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@id([userId, recipeId])
}

// ─── Amigos ─────────────────────────────────────────────────────

enum FriendshipStatus {
  PENDING
  ACCEPTED
}

model Friendship {
  id          String           @id @default(cuid())
  requesterId String
  addresseeId String
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  requester User @relation("SentFriendships", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("ReceivedFriendships", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId])
}

// ─── El Duelo (a dos, extensible a N) ───────────────────────────

enum DuelStatus {
  WAITING // esperando a que los invitados acepten
  ACTIVE // en juego
  FINISHED
  CANCELLED
}

model DuelSession {
  id            String     @id @default(cuid())
  hostId        String
  status        DuelStatus @default(WAITING)
  mealType      MealType?
  candidateIds  String[] // recetas aún en liza
  eliminatedIds String[] // vetadas, en orden
  turnUserId    String? // a quién le toca vetar
  winnerId      String? // receta campeona
  version       Int        @default(0) // para detectar cambios en el stream SSE
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  host         User              @relation("HostedDuels", fields: [hostId], references: [id], onDelete: Cascade)
  participants DuelParticipant[]

  @@index([hostId, status])
}

model DuelParticipant {
  id        String  @id @default(cuid())
  sessionId String
  userId    String
  order     Int // orden de turno (0, 1, ... N)
  accepted  Boolean @default(false)

  session DuelSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User        @relation("DuelParticipations", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([userId])
}

// ─── Hogar (plan y compra compartidos) ──────────────────────────

model Household {
  id        String   @id @default(cuid())
  name      String?
  createdAt DateTime @default(now())

  members   User[]
  weekPlans WeekPlan[]
  invites   HouseholdInvite[]
}

model HouseholdInvite {
  id          String   @id @default(cuid())
  householdId String
  inviterId   String
  inviteeId   String
  createdAt   DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  inviter   User      @relation("SentHouseholdInvites", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee   User      @relation("ReceivedHouseholdInvites", fields: [inviteeId], references: [id], onDelete: Cascade)

  @@unique([householdId, inviteeId])
  @@index([inviteeId])
}
